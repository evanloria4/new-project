{
  "compilerOptions": {
    "outDir": "./dist/",
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "noImplicitReturns": true,
    "noImplicitAny": true,
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "allowJs": true,
    "jsx": "react",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "tailwind.config.ts",
    ".eslintrc.js",
  ],
  "exclude": [
    "node_modules",
    "postcss.config.js",
  ]
}
